# Copy to `.env` for local dev. Vite exposes only VITE_* vars to the client.

# Backend API base URL — must include /api/v1 path prefix.
VITE_API_BASE_URL=https://localhost:5000/api/v1

# Default navigation layout: "sidebar" | "topbar"
VITE_DEFAULT_NAV_LAYOUT=sidebar

# App display name (shown in TopBar / browser title).
VITE_APP_NAME=ZarnTaxSync
